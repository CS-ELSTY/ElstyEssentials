                    "offset": [0, -1],
                    "bindings": [
                        {
                            "binding_collection_name": "form_buttons",
                            "binding_name": "#form_button_text",
                            "binding_type": "collection"
                        },
                        {
                            "binding_type": "view",
                            "source_property_name": "(not((#form_button_text - '§p§4§0')=#form_button_text))",
                            "target_property_name": "#visible"
                        }
                    ],
                    "$label_layer": 25
                }
            },
            {
                "label_>@style.label": {
                    "text": "§l>",
                    "$label_layer": 25,
                    "color": "$light_button_default_text_color",
                    "offset": [0, -1],
                    "bindings": [
                        {
                            "binding_collection_name": "form_buttons",
                            "binding_name": "#form_button_text",
                            "binding_type": "collection"
                        },
                        {
                            "binding_type": "view",
                            "source_property_name": "(not((#form_button_text - '§p§4§1')=#form_button_text))",
                            "target_property_name": "#visible"
                        }
                    ]
                }
            },
            {
                "label_?@style.label": {
                    "text": "§l?",
                    "$label_layer": 25,
                    "color": "$light_button_default_text_color",
                    "offset": [0, -1],
                    "bindings": [
                        {
                            "binding_collection_name": "form_buttons",
                            "binding_name": "#form_button_text",
                            "binding_type": "collection"
                        },
                        {
                            "binding_type": "view",
                            "source_property_name": "(not((#form_button_text - '§p§4§2')=#form_button_text))",
                            "target_property_name": "#visible"
                        }
                    ]
                }
            },
            {
                "label_!@style.label": {
                    "text": "§l!",
                    "$label_layer": 25,
                    "color": "$light_button_default_text_color",
                    "offset": [0, -1],
                    "bindings": [
                        {
                            "binding_collection_name": "form_buttons",
